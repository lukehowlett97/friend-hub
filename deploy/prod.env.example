# Copy to .env.prod and fill in real production values.
# Never commit .env.prod.

DOMAIN_NAME=chat.example.com

POSTGRES_USER=chatuser
POSTGRES_PASSWORD=replace-with-a-long-random-password
POSTGRES_DB=chatapp

DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=chatuser
DATABASE_PASSWORD=replace-with-the-same-value-as-postgres-password
DATABASE_NAME=chatapp

DEBUG=false
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=["https://chat.example.com"]

INVITE_CODE=replace-with-private-invite-code
APP_SECRET_KEY=replace-with-a-long-random-secret
AI_API_KEY=

# Chat embeddings (semantic /search). Off by default; the worker is the only
# thing that calls the embedding provider. fake | ollama | openai
AI_ENABLE_CHAT_EMBEDDINGS=false
AI_EMBEDDING_PROVIDER=ollama
AI_EMBEDDING_MODEL=nomic-embed-text
# Only needed when AI_EMBEDDING_PROVIDER=openai:
AI_EMBEDDING_API_KEY=
AI_EMBEDDING_BASE_URL=https://api.openai.com
# Semantic hits below this cosine similarity are dropped (keyword fallback kicks in).
# Measured on real data with nomic-embed-text: related 0.55+, unrelated <0.50.
AI_RETRIEVAL_SIMILARITY_FLOOR=0.50

BACKUP_RETENTION_DAYS=14

PHOTO_MAX_UPLOAD_BYTES=5242880
PHOTO_STORAGE_WARN_BYTES=21474836480
PHOTO_STORAGE_MAX_BYTES=30064771072
PHOTO_DISPLAY_MAX_WIDTH=1600
PHOTO_THUMBNAIL_MAX_WIDTH=480
PHOTO_JPEG_QUALITY=82
