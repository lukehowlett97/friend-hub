# Copy this to backend/app/.env and fill in real values.
# Never commit .env to git.

# App
DEBUG=false
HOST=127.0.0.1
PORT=8000

# Database — individual vars read by pydantic-settings
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=chatuser
DATABASE_PASSWORD=changeme
DATABASE_NAME=chatapp

# CORS (JSON list — add production origin here when deploying)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Private beta auth
INVITE_CODE=howlett

# WebSocket limits
WS_MAX_MESSAGE_BYTES=2000
WS_RATE_LIMIT_MESSAGES=10
WS_RATE_LIMIT_WINDOW_SECONDS=5

# AI / Hub Bot
# Get a free key at https://openrouter.ai
AI_API_KEY=
AI_API_PROVIDER=openrouter
AI_DEFAULT_CHAT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
AI_HUB_RATE_LIMIT_PER_MINUTE=5
AI_MONTHLY_BUDGET_CENTS=0

# Photo uploads
PHOTO_MAX_UPLOAD_BYTES=5242880
PHOTO_STORAGE_WARN_BYTES=21474836480
PHOTO_STORAGE_MAX_BYTES=30064771072
PHOTO_DISPLAY_MAX_WIDTH=1600
PHOTO_THUMBNAIL_MAX_WIDTH=480
PHOTO_JPEG_QUALITY=82
